using System;

class Program
{
    static void Main()
    {
        Console.Write("¿Es socio? (true/false): ");
        bool esSocio = Convert.ToBoolean(Console.ReadLine());

        Console.Write("Ingrese el valor de compra: ");
        double compra = Convert.ToDouble(Console.ReadLine());

        bool acceso = esSocio || compra > 500;

        Console.WriteLine("Acceso preferencial: " + acceso);
    }
}
